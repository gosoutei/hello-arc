# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Load before running forge/cast commands:
#   source .env

# Arc Testnet RPC (https://docs.arc.io/arc/references/rpc-endpoints)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Deployer / signer private key (never commit the real value)
# Create a wallet: cast wallet new ~/.foundry/keystores my_wallet
PRIVATE_KEY=

# Optional: live gas price in wei for SweepUsdc.s.sol
# Fetch before sweeping: cast gas-price --rpc-url $ARC_TESTNET_RPC_URL
GAS_PRICE=

# Optional: set after deploying Counter (forge create / forge script)
COUNTER_ADDRESS=
